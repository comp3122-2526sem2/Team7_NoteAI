# ── Database ──────────────────────────────────────────────────────────────────
# Format: postgresql://<user>:<password>@<host>:<port>/<dbname>
# Default matches the compose.yml postgres service.
DATABASE_URL=postgresql://noteai:noteai@noteai_postgres:5432/noteai

# ── AnythingLLM ───────────────────────────────────────────────────────────────
# Base URL of the AnythingLLM API. Use the Docker service name inside compose.
ANYTHINGLLM_BASE_URL=http://noteai-anythingllm:3001/api
# Generate an API key in the AnythingLLM UI: Settings → Security → API Keys
ANYTHINGLLM_API_KEY=

# ── OpenAI ────────────────────────────────────────────────────────────────────
# Required: your OpenAI API key (or a compatible service key).
OPENAI_API_KEY=
# Optional: override the default https://api.openai.com/v1 endpoint
# (e.g. Azure OpenAI, local LM Studio, Ollama-compatible server).
OPENAI_BASE_URL=
# Optional: default model (default: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini
# Optional: request timeout in seconds (default: 60)
OPENAI_TIMEOUT=60

# ── Auth / JWT ────────────────────────────────────────────────────────────────
# Secret used to sign JWT access tokens. Use a long random string in production.
JWT_SECRET=change_me_in_production
# Token expiry in minutes (default 60)
ACCESS_TOKEN_EXPIRE_MINUTES=60
